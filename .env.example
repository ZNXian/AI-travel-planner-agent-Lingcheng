# ===== 阿里百炼 (DashScope) =====
# 在 https://dashscope.console.aliyun.com/ 申请，复制后粘贴到这里
DASHSCOPE_API_KEY=

# OpenAI 兼容模式的访问地址，一般无需修改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型名称（建议保持 qwen-max；也可换成 qwen-plus 等）
QWEN_MODEL=qwen-max

# ===== 飞猪 FlyAI =====
# 在 https://flyai.open.fliggy.com/console 申请，复制后粘贴到这里
FLYAI_API_KEY=
# 真实酒店/POI 查询通过 npx @fly-ai/flyai-cli 调用，需已安装 Node.js（含 npx）

# ===== Gradio =====
# 监听地址与端口（如需对外暴露改为 0.0.0.0）
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860

# ===== 日志 =====
# 是否在终端同时输出 INFO 日志（1/true 开启，0/false/no 仅写 lingcheng.log）
LINGCHENG_LOG_CONSOLE=1
